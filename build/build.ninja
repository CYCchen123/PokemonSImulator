  OBJECT_DIR = CMakeFiles\PokemonSimulator.dir
  POST_BUILD = cd .
  PRE_LINK = cd .
  TARGET_FILE = PokemonSimulator.exe
  TARGET_IMPLIB = libPokemonSimulator.dll.a
  TARGET_PDB = PokemonSimulator.exe.dbg
  TARGET_SUPPORT_DIR = CMakeFiles\PokemonSimulator.dir


#############################################
# Utility command for edit_cache

build CMakeFiles/edit_cache.util: CUSTOM_COMMAND
  COMMAND = C:\WINDOWS\system32\cmd.exe /C "cd /D E:\PokemonSImulator\build && "C:\Program Files\CMake\bin\cmake-gui.exe" -SE:\PokemonSImulator -BE:\PokemonSImulator\build"
  DESC = Running CMake cache editor...
  pool = console
  restat = 1

build edit_cache: phony CMakeFiles/edit_cache.util


#############################################
# Utility command for rebuild_cache

build CMakeFiles/rebuild_cache.util: CUSTOM_COMMAND
  COMMAND = C:\WINDOWS\system32\cmd.exe /C "cd /D E:\PokemonSImulator\build && "C:\Program Files\CMake\bin\cmake.exe" --regenerate-during-build -SE:\PokemonSImulator -BE:\PokemonSImulator\build"
  DESC = Running CMake to regenerate build system...
  pool = console
  restat = 1

build rebuild_cache: phony CMakeFiles/rebuild_cache.util

# =============================================================================
# Target aliases.

build PokemonSimulator: phony PokemonSimulator.exe

build battle_core: phony libbattle_core.a

build sqlite3: phony libsqlite3.a

