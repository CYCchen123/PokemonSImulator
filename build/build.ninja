# Link build statements for EXECUTABLE target PokemonSimulator


#############################################
# Link the executable PokemonSimulator.exe

build PokemonSimulator.exe: CXX_EXECUTABLE_LINKER__PokemonSimulator_ CMakeFiles/PokemonSimulator.dir/src/main.cpp.obj | libbattle_core.a libsqlite3.a || libbattle_core.a libsqlite3.a
