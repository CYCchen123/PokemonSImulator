# ============================================================
# PokemonSimulator Docker Compose 环境变量
# 复制此文件为 .env 并填写实际值
# ============================================================

# === Kafka (物理机集群, Person C) ===
# 格式: host1:9092,host2:9092,host3:9092
KAFKA_BROKER=100.107.105.99:9092,<node2-tailscale-ip>:9092,<node3-tailscale-ip>:9092

# === HDFS (物理机集群, Person B) ===
HDFS_NAMENODE=100.107.105.99
HDFS_PORT=9870
HDFS_USER=root

# === Redis (物理机集群, Person C) ===
REDIS_URL=redis://100.107.105.99:6379/0

# === Spark (物理机集群, Person B) ===
SPARK_MASTER_URL=spark://100.107.105.99:7077
SPARK_REST_URL=http://100.107.105.99:6066

# === PostgreSQL ===
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=pokemon
POSTGRES_PASSWORD=pokemon123
POSTGRES_DB=pokemon_simulator

# === App ===
DEBUG=false
